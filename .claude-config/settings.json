{
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Glob(**)",
      "Grep(**)",
      "WebSearch",
      "WebFetch(*)",
      "Skill(*)",
      "Task(*)",
      "Bash(*)",
      "mcp__plugin_supabase_supabase__*",
      "mcp__plugin_playwright_playwright__*",
      "Read(//c/Users/Alejandro/.claude/tools/figma-cli/**)",
      "Read(//c/Users/Alejandro/.claude/**)",
      "mcp__plugin_figma_figma__*",
      "Read(//c/Users/Alejandro/Downloads/**)",
      "Read(//c/Users/Alejandro/Desktop/**)",
      "Read(//c/Users/Alejandro/sistema-os/docs/proposta-pj/**)",
      "Read(//c/Users/Alejandro/concierge-platform/**)",
      "Read(//c/Users/Alejandro/sistema-os/**)",
      "mcp__pencil"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r /*)",
      "Bash(rm -r ~*)",
      "Bash(sudo rm -rf *)",
      "Bash(sudo rm -r *)",
      "Bash(dd if=*)",
      "Bash(mkfs*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git checkout -- .)",
      "Bash(git restore .)",
      "Bash(git merge * main)",
      "Bash(> /dev/sd*)",
      "Bash(chmod 777 *)"
    ],
    "additionalDirectories": [
      "C:\\Users\\Alejandro\\.claude\\tools\\figma-cli\\src",
      "C:\\Users\\Alejandro\\.claude\\tools\\figma-cli\\scripts",
      "c:\\Users\\Alejandro\\.claude"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.bun/bin/bun run ~/.claude/hooks/initialize-session.ts"
          },
          {
            "type": "command",
            "command": "~/.bun/bin/bun run ~/.claude/hooks/load-core-context.ts"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.bun/bin/bun run ~/.claude/hooks/security-validator.ts"
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "~/.bun/bin/bun run ~/.claude/hooks/worktree-auto-approve.ts"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.bun/bin/bun run ~/.claude/hooks/update-tab-titles.ts"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.bun/bin/bun run ~/.claude/hooks/statusline.ts",
    "padding": 0
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "figma@claude-plugins-official": true
  },
  "language": "PT-BR",
  "alwaysThinkingEnabled": true
}
